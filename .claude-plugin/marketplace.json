{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "ben-plugins",
  "description": "ben 的 Claude Code 插件集合，包含个人研发流程等自定义插件",
  "owner": {
    "name": "ben",
    "email": "benbowenqwe@gmail.com"
  },
  "plugins": [
    {
      "name": "dev-flow",
      "description": "个人研发流程插件：从 PRD 到交付的完整 8 步工作流，自动编排需求分析、提问对齐、技术方案、编码、自测、CR、总结",
      "author": {
        "name": "ben",
        "email": "benbowenqwe@gmail.com"
      },
      "source": "./plugins/dev-flow",
      "category": "development",
      "homepage": "https://github.com/benbowenqwe/ben-plugins/tree/main/plugins/dev-flow"
    },
    {
      "name": "uniplat",
      "description": "Uniplat 低代码平台开发辅助：JSON+Groovy 模型/Action/服务脚手架与编码规范，让 Claude Code 快速准确地在 Uniplat 平台上开发",
      "author": {
        "name": "ben",
        "email": "benbowenqwe@gmail.com"
      },
      "source": "./plugins/uniplat",
      "category": "development",
      "homepage": "https://github.com/benbowenqwe/ben-plugins/tree/main/plugins/uniplat"
    },
    {
      "name": "dev-flow-lite",
      "description": "简版研发流程插件：读 PRD → 提问对齐 → 编码 → Code Review，不写 MD、不做断点续传，适合小需求快速迭代",
      "author": {
        "name": "ben",
        "email": "benbowenqwe@gmail.com"
      },
      "source": "./plugins/dev-flow-lite",
      "category": "development",
      "homepage": "https://github.com/benbowenqwe/ben-plugins/tree/main/plugins/dev-flow-lite"
    }
  ]
}
